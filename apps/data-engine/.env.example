# Data Engine (NestJS) - copy to .env, do not commit
# Broker is any RESP-compatible implementation:
#   Redis 7+ / Memurai (Windows) / Dragonfly / Valkey / KeyDB / Garnet / Redict

# --- Required (all modes) ---
ARGOS_BROKER_URL=redis://localhost:6379
ENVIRONMENT_MODE=PAPER_TRADING

# --- Exchange WebSocket ---
EXCHANGE_WS_URL=wss://stream.binance.com:9443/ws
SYMBOL=BTC/USDT

# --- Trading config ---
TIMEFRAME=1m

# --- Notifications (webhooks) ---
# Telegram bot (optional). Get token from @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord webhook (optional).
DISCORD_WEBHOOK_URL=

# --- Optional ---
STREAM_PREFIX=ticks:
TICK_BUFFER_CAP=100
