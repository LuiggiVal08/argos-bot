# Analytics Engine (FastAPI) - copy to .env, do not commit
# Broker is any RESP-compatible implementation:
#   Redis 7+ / Memurai (Windows) / Dragonfly / Valkey / KeyDB / Garnet / Redict

# --- Required (all modes) ---
ARGOS_BROKER_URL=redis://localhost:6379
ENVIRONMENT_MODE=PAPER_TRADING

# --- Required for LIVE mode ---
# If ENVIRONMENT_MODE=LIVE and these are missing/empty, init aborts.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# --- Optional ---
EXCHANGE_PASSPHRASE=          # Required by some exchanges (e.g. OKX)
EXCHANGE_ID=binanceusdm       # Default: binanceusdm (Binance USDⓈ-M futures)

# --- Risk defaults ---
RISK_PCT=0.01                 # 1% max risk per trade
DRAWDOWN_PCT=0.05             # 5% max daily drawdown before circuit breaker
