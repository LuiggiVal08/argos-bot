# Analytics Engine (FastAPI) - copy to .env, do not commit
# Broker is any RESP-compatible implementation:
#   Redis 7+ / Memurai (Windows) / Dragonfly / Valkey / KeyDB / Garnet / Redict

# --- Required (all modes) ---
ARGOS_BROKER_URL=redis://localhost:6379
ENVIRONMENT_MODE=PAPER_TRADING

# --- Required for LIVE mode ---
# If ENVIRONMENT_MODE=LIVE and these are missing/empty, init aborts.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# --- Binance Spot Testnet (PAPER_TRADING / LIVE) ---
# When BINANCE_TESTNET=true, the engine uses Binance Spot Testnet
# instead of futures. Requires these vars (non-empty):
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=
BINANCE_TESTNET=true

# --- Optional ---
EXCHANGE_PASSPHRASE=          # Required by some exchanges (e.g. OKX)
EXCHANGE_ID=binanceusdm       # Default: binanceusdm (Binance USDⓈ-M futures)

# --- Notifications (webhooks) ---
# These are consumed by the data-engine (Node/NestJS) which dispatches
# to Telegram/Discord. If none are set, notifications are no-op.
TELEGRAM_BOT_TOKEN=           # Bot token from @BotFather
TELEGRAM_CHAT_ID=             # Chat/channel ID to receive alerts
DISCORD_WEBHOOK_URL=          # Discord webhook URL

# --- Risk defaults ---
RISK_PCT=0.01                 # 1% max risk per trade
DRAWDOWN_PCT=0.05             # 5% max daily drawdown before circuit breaker
